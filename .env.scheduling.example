# ── Gmail SMTP (sends ALL emails: OTP, meeting confirmations, approvals, reminders) ─
# These are already required for admin login OTP — same vars, same Gmail account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=as.premiumportfolio@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx    # Gmail App Password (NOT your regular password)
                                   # Generate at: https://myaccount.google.com/apppasswords

# ── Admin notification recipient ─────────────────────────────────────────────
ADMIN_EMAIL=as.premiumportfolio@gmail.com

# ── App URL (used in email links) ─────────────────────────────────────────────
NEXTAUTH_URL=https://yourportfolio.vercel.app

# ── Optional: Google Calendar API (auto-generates real Meet links on approval) ─
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# ── Optional: Calendly integration ───────────────────────────────────────────
# CALENDLY_API_TOKEN=
# CALENDLY_USER_URI=
# CALENDLY_EVENT_TYPE_URI=

# ── Cron secret (protects /api/cron/* endpoints) ─────────────────────────────
CRON_SECRET=your-secret-here
